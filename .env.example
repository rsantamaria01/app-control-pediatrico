# ─────────────────────────────────────────────────────────────────
# App database (read-write)
# ─────────────────────────────────────────────────────────────────
# DATABASE_TYPE controls the TypeORM driver. Switching engines requires
# only changing these two env vars; no code changes are needed.
#   sqlite   -> DATABASE_URL is a file path (relative to the api process)
#   postgres -> DATABASE_URL is a postgres:// connection string
DATABASE_TYPE=sqlite
DATABASE_URL=./data/data.db
# DATABASE_TYPE=postgres
# DATABASE_URL=postgres://app:app@localhost:5432/app

# ─────────────────────────────────────────────────────────────────
# WHO database (read-only, always SQLite)
# ─────────────────────────────────────────────────────────────────
WHO_DATABASE_PATH=./data/who.db

# ─────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────────────────────────────────
# OTP
# ─────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_MINUTES=10

# ─────────────────────────────────────────────────────────────────
# Notification channels (comma-separated)
# Allowed: EMAIL, SMS, WHATSAPP, TELEGRAM
# ─────────────────────────────────────────────────────────────────
NOTIFICATION_CHANNELS=EMAIL

# Email (Nodemailer, SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Pediatric Growth <no-reply@example.com>"

# Twilio (stubbed)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Telegram (stubbed)
TELEGRAM_BOT_TOKEN=

# WhatsApp (stubbed)
WHATSAPP_API_KEY=

# ─────────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────────
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# Web
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
