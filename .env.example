# ─────────────────────────────────────────────────────────────────
# App database — Postgres only (single engine).
# Inside docker-compose the API talks to the `db` service.
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://app:app@db:5432/app
# Local dev outside docker:
# DATABASE_URL=postgres://app:app@localhost:5432/app

# Postgres credentials used by the `db` service in docker-compose.
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────────
# CDC growth-chart LMS reference data (read-only static CSV files).
# Files follow: <xAxis>_<yAxis>_<initialMonth>_<lastMonth>.csv
#   a  = age, w = weight, h = height/stature, l = length,
#   b  = bmi, hc = head circumference
# Examples shipped in data/lms/:
#   w_a_0_240.csv, h_a_0_240.csv, b_a_24_240.csv,
#   hc_a_0_36.csv, w_h_45_121.csv (x-axis is cm here, not months)
# ─────────────────────────────────────────────────────────────────
LMS_DATA_DIR=./data/lms

# ─────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────────────────────────────────
# OTP
# ─────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_MINUTES=10

# ─────────────────────────────────────────────────────────────────
# Notification channels (all optional — auto-enabled when configured).
#
# A channel is enabled iff its credentials below are set. When NO
# channel is configured the API has no way to send a verification
# code, so:
#   - parent contacts added by a doctor/admin are marked verified
#     immediately (the doctor is asserting they entered correct data)
#   - OTP login is unavailable; users must sign in with a password
# ─────────────────────────────────────────────────────────────────

# Email — SMTP (Nodemailer). Empty SMTP_HOST disables email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Pediatric Growth <no-reply@example.com>"

# SMS — Twilio. All three vars must be set for SMS to be enabled.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# WhatsApp — empty key disables the channel.
WHATSAPP_API_KEY=

# Telegram — empty token disables the channel.
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────────
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000

# Bootstrap ADMIN user, seeded on first boot.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme1234

# ─────────────────────────────────────────────────────────────────
# Web
# ─────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
